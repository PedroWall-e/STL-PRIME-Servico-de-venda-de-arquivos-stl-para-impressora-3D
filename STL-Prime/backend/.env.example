# ==========================================
# 🛠️ STL Prime Backend - Environment Variables
# ==========================================

# 1. Chave Secreta da API (Usada para JWTs e Tokens FastAPI)
# Substitua por uma chave forte em produção (ex: gerada com `openssl rand -hex 32`)
SECRET_KEY="prime_super_secret_key_frontier_data"

# 2. Database
# Nota: O Docker Compose já injeta essa variável automaticamente,
# mas se quiser debugar localmente fora do docker, descomente e use:
# DATABASE_URL="mysql+pymysql://stl_user:stl_password@localhost:3306/stl_prime"
